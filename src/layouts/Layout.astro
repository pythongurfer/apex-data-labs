---
// src/layouts/Layout.astro
import '~/assets/styles/tailwind.css';
import '/public/styles/global.css';

import { SITE } from 'astrowind:config';
import { I18N } from 'astrowind:config';

import Header from '~/components/widgets/Header.astro'; // ADDED
import Footer from '~/components/widgets/Footer.astro'; // ADDED
import CommonMeta from '~/components/common/CommonMeta.astro';
import Favicons from '~/components/Favicons.astro';
import CustomStyles from '~/components/CustomStyles.astro';
import ApplyColorMode from '~/components/common/ApplyColorMode.astro';
import Metadata from '~/components/common/Metadata.astro';
import BasicScripts from '~/components/common/BasicScripts.astro';
import Analytics from '~/components/common/Analytics.astro';
import SiteVerification from '~/components/common/SiteVerification.astro';

import { headerData, footerData } from '~/navigation'; // ADDED
import type { MetaData as MetaDataType } from '~/types';

export interface Props {
  metadata?: MetaDataType;
}

const { metadata = {} } = Astro.props;
const { language, textDirection } = I18N;
const siteStructuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${SITE.site}/#website`,
      url: SITE.site,
      name: SITE.name,
      inLanguage: language,
    },
    {
      '@type': 'Organization',
      '@id': `${SITE.site}/#organization`,
      name: 'Apex Data Labs',
      url: SITE.site,
      sameAs: ['https://github.com/pythongurfer/apex-data-labs'],
    },
    {
      '@type': 'Person',
      '@id': `${SITE.site}/#person`,
      name: 'Anika Rosenzuaig',
      url: `${SITE.site}/about`,
      sameAs: ['https://www.linkedin.com/in/anikarosenzuaig/', 'https://github.com/pythongurfer'],
      worksFor: {
        '@id': `${SITE.site}/#organization`,
      },
    },
  ],
};
---

<!doctype html>
<html lang={language} dir={textDirection} class="2xl:text-[20px]">
  <head>
    <CommonMeta />
    <Favicons />
    <CustomStyles />
    <ApplyColorMode />
    <Metadata {...metadata} />
    <meta charset="utf-8" />
    <script type="application/ld+json" set:html={JSON.stringify(siteStructuredData)} />
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.css" integrity="sha384-GvrOXuhMATgEsSwCs4smul74iXGOixntILdUW9XmUC6+HX0sLNAK3q71HotJqlAn" crossorigin="anonymous">
    <Analytics />
    <SiteVerification />
  </head>

  <body class="antialiased text-default bg-page tracking-tight">
    <Header {...headerData} isSticky showRssFeed showToggleTheme />

    <main>
      <slot />
    </main>

    <Footer {...footerData} />

    <BasicScripts />
  </body>
</html>